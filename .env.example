# -- APLIKASI --
APP_NAME=Collabee
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# -- LOKALISASI --
APP_LOCALE=id
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=id_ID

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

# -- LOGGING --
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# -- DATABASE --
# Default: SQLite (no config needed)
DB_CONNECTION=sqlite
# Untuk MySQL, uncomment dan set di bawah:
# DB_CONNECTION=mysql
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=collabee
# DB_USERNAME=root
# DB_PASSWORD=

# -- SESSION --
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# -- BROADCASTING (Reverb WebSocket) --
BROADCAST_CONNECTION=reverb

# -- FILESYSTEM --
FILESYSTEM_DISK=local

# -- QUEUE (Horizon via Redis) --
QUEUE_CONNECTION=redis

# -- CACHE --
CACHE_STORE=redis
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

# -- REDIS --
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# -- MAIL --
# Dev: Mailtrap
MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=sandbox.smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS="hello@collabee.com"
MAIL_FROM_NAME="${APP_NAME}"
# Production: Mailgun
# MAIL_MAILER=mailgun
# MAILGUN_DOMAIN=
# MAILGUN_SECRET=

# -- AWS S3 (Media Storage) --
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=ap-southeast-1
AWS_BUCKET=collabee-media
AWS_USE_PATH_STYLE_ENDPOINT=false

# -- XENDIT (Payment Gateway) --
XENDIT_API_KEY=
XENDIT_WEBHOOK_TOKEN=

# -- LARAVEL REVERB (WebSocket) --
REVERB_APP_ID=
REVERB_APP_KEY=
REVERB_APP_SECRET=
REVERB_HOST=localhost
REVERB_PORT=8080
REVERB_SCHEME=http
REVERB_SERVER_HOST=0.0.0.0
REVERB_SERVER_PORT=8080

# -- HORIZON (Queue Monitoring) --
HORIZON_NAME=collabee-horizon
HORIZON_DOMAIN=
HORIZON_PATH=horizon

# -- LARAVEL SCOUT (Search) --
SCOUT_DRIVER=database
# MeiliSearch
# MEILISEARCH_HOST=http://localhost:7700
# MEILISEARCH_KEY=
# Algolia
# ALGOLIA_APP_ID=
# ALGOLIA_SECRET=

# -- VITE --
VITE_APP_NAME="${APP_NAME}"
VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"
