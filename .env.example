# -- APLIKASI --
APP_NAME=Collabee
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=https://collabee.ismimaulidia.studio

# -- LOKALISASI --
APP_LOCALE=id
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=id_ID

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

# -- LOGGING --
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# -- DATABASE --
# Default: SQLite (local dev). For production use MySQL and set the values below.
# Set DB_CONNECTION=mysql for production
DB_CONNECTION=sqlite
# Production example (uncomment and set values):
# DB_CONNECTION=mysql
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=collabee
# DB_USERNAME=collabee
# DB_PASSWORD=your_strong_password

# -- SESSION --
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# -- BROADCASTING (Reverb WebSocket) --
BROADCAST_CONNECTION=reverb

# -- FILESYSTEM --
FILESYSTEM_DISK=local

# -- QUEUE (Horizon via Redis) --
QUEUE_CONNECTION=redis

# -- CACHE --
CACHE_STORE=redis
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

# -- REDIS --
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# -- MAIL --
# Dev: Resend (https://resend.com)
MAIL_MAILER=resend
RESEND_API_KEY=
MAIL_FROM_ADDRESS="hello@collabee.ismimaulidia.studio"
MAIL_FROM_NAME="${APP_NAME}"

# -- AWS S3 (Media Storage) --
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=ap-southeast-1
AWS_BUCKET=collabee-media
AWS_USE_PATH_STYLE_ENDPOINT=false

# -- XENDIT (Payment Gateway) --
XENDIT_API_KEY=
XENDIT_WEBHOOK_TOKEN=

# -- LARAVEL REVERB (WebSocket) --
REVERB_APP_ID=
REVERB_APP_KEY=
REVERB_APP_SECRET=
REVERB_HOST=localhost
REVERB_PORT=8080
REVERB_SCHEME=http
REVERB_SERVER_HOST=0.0.0.0
REVERB_SERVER_PORT=8080

# -- HORIZON (Queue Monitoring) --
HORIZON_NAME=collabee-horizon
HORIZON_DOMAIN=
HORIZON_PATH=horizon

# -- LARAVEL SCOUT (Search) --
SCOUT_DRIVER=database
# MeiliSearch
# MEILISEARCH_HOST=http://localhost:7700
# MEILISEARCH_KEY=
# Algolia
# ALGOLIA_APP_ID=
# ALGOLIA_SECRET=

# -- VITE --
VITE_APP_NAME="${APP_NAME}"
VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"

#############################################
# Production placeholders (REQUIRED)
#############################################
# Set these values before running in production
# APP_ENV=production
# APP_DEBUG=false
# APP_URL=https://your.domain.com

# DB connection (production example)
# DB_CONNECTION=mysql
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=collabee
# DB_USERNAME=collabee
# DB_PASSWORD=your_strong_password

# Redis (production)
# REDIS_HOST=127.0.0.1
# REDIS_PASSWORD=null
# REDIS_PORT=6379

# Mail (production provider settings)
# MAIL_MAILER=smtp
# MAIL_HOST=smtp.mailgun.org
# MAIL_PORT=587
# MAIL_USERNAME=your_mail_username
# MAIL_PASSWORD=your_mail_password

# AWS S3 (if used)
# FILESYSTEM_DISK=s3
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_BUCKET=

# Xendit (production)
# XENDIT_API_KEY=
# XENDIT_WEBHOOK_TOKEN=
